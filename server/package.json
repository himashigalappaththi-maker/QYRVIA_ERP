{
  "name": "qyrvia-server",
  "version": "0.1.0",
  "private": true,
  "description": "QYRVIA Enterprise ERP backend - Phase 1 kernel foundation",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node src/db/migrate.js up",
    "migrate:status": "node src/db/migrate.js status",
    "test": "node --test \"test/**/*.test.js\"",
    "test:unit": "node --test \"test/*.test.js\"",
    "test:db": "node --test --test-concurrency=1 \"test/db/**/*.db.test.js\"",
    "db:provision": "node scripts/ci-provision-db.js",
    "db:preflight": "node scripts/rls-preflight.js",
    "test:db-safe": "node scripts/run-db-tests.js",
    "test:db:guarded": "npm run db:preflight && npm run test:db",
    "db:test:up": "docker compose -f test/db/docker-compose.test.yml up -d",
    "db:test:down": "docker compose -f test/db/docker-compose.test.yml down -v"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "pino": "^9.0.0"
  }
}
