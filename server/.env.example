# QYRVIA Server - environment template.
# Copy to `.env` and fill in real values. The real `.env` is gitignored.
# The process refuses to boot if any REQUIRED key below is missing.

# --- REQUIRED -------------------------------------------------------------

# PostgreSQL connection string (any libpq URI form works).
DATABASE_URL=postgresql://qyrvia:secret@localhost:5432/qyrvia

# JWT signing secret. Minimum 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# --- OPTIONAL -------------------------------------------------------------

# Previous JWT secret for graceful rotation. New tokens are signed with
# JWT_SECRET; verification accepts both. After rotation + > ACCESS_TOKEN_TTL,
# unset JWT_SECRET_PREV.
JWT_SECRET_PREV=

# Token TTLs
ACCESS_TOKEN_TTL_SEC=900       # 15 minutes
REFRESH_TOKEN_TTL_DAYS=30

# bcrypt cost factor (10..15 reasonable; 12 = ~150ms per hash)
BCRYPT_ROUNDS=12

# HTTP
PORT=3001

# pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Runtime mode: development | production | test
NODE_ENV=development

# Error envelope format: string | object
ERROR_ENVELOPE=string

# DB observability (low-cardinality metrics + slow-query; SQL hash only, never text)
DB_OBSERVABILITY=true

# --- CHANNEL MANAGER (safe defaults; keep OTA egress OFF unless a reviewed phase enables it) ---

# Persistence mode for channel stores: memory | (durable mode once infra is provisioned)
CHANNEL_PERSISTENCE=memory

# 32-byte key that encrypts channel credentials at rest (Phase 40 credential vault).
# Empty => the credential vault is dormant. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CHANNEL_CREDENTIAL_KEY=

# Durable queue worker (MOCK processor; not wired to real OTA). Default off.
CHANNEL_WORKER_ENABLED=false

# Inbound webhook ingress. Default off.
CHANNEL_WEBHOOK_ENABLED=false

# LIVE OTA HTTP transport. KEEP false. Do not enable outside an approved OTA phase.
CHANNEL_HTTP_ENABLED=false

# Channels that use the internal (non-network) real-sync path. Default: QYRVIA's own engine.
CHANNEL_REALSYNC_CHANNELS=QTCN

# Explicit live OTA activations. Leave empty (no live OTA).
CHANNEL_OTA_ACTIVATIONS=

# Canonical adapter registry as the source of truth.
CHANNEL_CANONICAL_CORE=true

# --- AI (all default OFF; no vendor HTTP until reviewed) ---

AI_AGENT_ENABLED=false
AI_PROVIDER=anthropic
AI_FALLBACK_PROVIDER=openai
AI_TERTIARY_PROVIDER=gemini
AI_LLM_ENABLED=false
AI_LLM_ENDPOINT=
AI_LLM_MODEL=gpt-4o-mini
AI_LLM_CREDENTIALS_REF=
AI_CONFIRMATION_ENABLED=false
AI_CONFIRMATION_AUTO_SEND=true
AI_CONFIRMATION_MIN_CONFIDENCE=0.5
AI_CONFIRMATION_TRANSPORT=mock
